{
  "name": "@acme/storybook",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel/examples.git"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build": "pnpm build-storybook",
    "build-storybook": "storybook build",
    "preview-storybook": "http-server storybook-static --port 6006",
    "test-storybook": "NODE_ENV=test test-storybook",
    "test-storybook:watch": "test-storybook --watch",
    "lint": "TIMING=1 eslint \".storybook/*.{ts,tsx,js,jsx}\" --fix",
    "clean": "rm -rf .turbo",
    "chromatic": "./scripts/chromatic.sh",
    "test": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"http-server storybook-static --port 6006 --silent\" \"wait-on http://127.0.0.1:6006 && pnpm test-storybook\""
  },
  "dependencies": {
    "@acme/design-system": "workspace:*",
    "@vercel/examples-ui": "^2.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "save-dev": "0.0.1-security"
  },
  "devDependencies": {
    "@playwright/test": "^1.39.0",
    "@storybook/addon-a11y": "^7.5.2",
    "@storybook/addon-coverage": "^0.0.9",
    "@storybook/addon-docs": "^7.5.2",
    "@storybook/addon-essentials": "^7.5.2",
    "@storybook/addon-interactions": "^7.5.2",
    "@storybook/addon-jest": "^7.5.2",
    "@storybook/addon-links": "^7.5.2",
    "@storybook/addon-onboarding": "^1.0.8",
    "@storybook/cli": "^7.5.2",
    "@storybook/jest": "^0.2.3",
    "@storybook/preset-typescript": "^3.0.0",
    "@storybook/react": "^7.5.2",
    "@storybook/react-vite": "^7.5.2",
    "@storybook/test-runner": "^0.13.0",
    "@swc/core": "^1.3.96",
    "autoprefixer": "^10.4.16",
    "chromatic": "^7.6.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.53.0",
    "eslint-config-acme": "workspace:*",
    "eslint-plugin-storybook": "^0.6.15",
    "http-server": "^14.1.1",
    "install": "^0.13.0",
    "msw": "^1.3.2",
    "msw-storybook-addon": "^1.10.0",
    "nyc": "^15.1.0",
    "playwright": "^1.39.0",
    "postcss": "^8.4.31",
    "serve": "^14.2.1",
    "storybook": "^7.5.2",
    "storybook-addon-swc": "^1.2.0",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^4.5.0",
    "wait-on": "^7.1.0"
