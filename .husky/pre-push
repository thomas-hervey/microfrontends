# .husky/pre-push

#!/bin/sh

echo "*********************************"
echo "HUSKY: Running pre-push checks..."

# CHECK 1: Does branch name start with 'feature/BUG_' or 'feature/ENH_' or is 'develop' or 'main'?
branch_name=$(git symbolic-ref --short HEAD)
if ! echo "$branch_name" | grep -qE '^(main|develop|feature/BUG_|feature/ENH_).*'; then
  echo "- Error: Invalid branch name."
  echo "Branch name must start with 'BUG_' or 'ENH_'."
  exit 1
fi

# CHECK 2: Make sure tests pass
npm run test
